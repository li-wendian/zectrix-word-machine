# OTA 地址（--ota-url 参数可覆盖）
DEFAULT_OTA_URL=https://ota.zectrix.com/zectrix-word-machine/ota/

# 预设WiFi（编译时注入，避免每次刷机重新配网）
DEFAULT_WIFI_SSID=
DEFAULT_WIFI_PASSWORD=

# 本地后台/OTA 目录同步，默认关闭，避免公开构建时写入仓库外目录
SYNC_LOCAL_OUTPUTS=false
# MANAGER_NEXT_DIR=../main/manager-next
# OTA_BIN_DIR=../main/zectrix-server/data/bin
